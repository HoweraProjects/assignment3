# Default: local Ollama
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# Context window for long RAG prompts (Ollama)
OLLAMA_NUM_CTX=16384

# Retrieval: MMR (default) or similarity; fetch window for MMR
# RETRIEVER_K=12
# RETRIEVER_FETCH_K=60
# RETRIEVER_SEARCH_TYPE=mmr

# Optional: cloud LLMs
# LLM_PROVIDER=google
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash

# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Embeddings (HuggingFace). Compare models for the report:
# EMBEDDING_TAG=miniLM
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#
# EMBEDDING_TAG=bge
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Chunking experiments (default 2000 / 200 per assignment)
# CHUNK_SIZE=2000
# CHUNK_OVERLAP=200

# Evaluator: GRAPH (LangGraph) or LEGACY (ReAct)
# EVAL_MODE=GRAPH

# Set to 1 to use only the LLM grader (no rule-based pass layer)
# DISABLE_DETERMINISTIC_GRADE=0
